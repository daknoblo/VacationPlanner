# Copy to .env and adjust. Never commit real secrets.

# ---- Runtime ----
APP_ENV=development
HTTP_ADDR=:8080

# ---- Database (PostgreSQL) ----
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://vacation:vacation@localhost:5432/vacation?sslmode=disable

# ---- OpenAI-compatible AI endpoint ----
# Works with OpenAI, Azure OpenAI, Ollama, LocalAI, vLLM, ...
# Leave OPENAI_API_KEY empty to disable AI features.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Security ----
# 32-byte key, hex-encoded (64 hex chars). Generate with:
#   openssl rand -hex 32
# If empty in development an ephemeral key is generated on startup.
CSRF_KEY=
