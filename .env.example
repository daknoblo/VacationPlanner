# Copy to .env and adjust. Never commit real secrets.
# Every variable is OPTIONAL — the app runs with sensible defaults. In practice you
# typically only set VP_API_KEY (for AI) and, in production, CSRF_KEY.

# ---- AI (optional) ----
# API key for the OpenAI-compatible endpoint. Empty = AI features disabled.
# The endpoint URL and model are configured in the app under Settings, not here.
VP_API_KEY=

# ---- Security ----
# HMAC key that signs CSRF tokens (hex, >= 32 bytes). Generate with:
#   openssl rand -hex 32
# Optional in development (an ephemeral key is generated on startup);
# REQUIRED in production so tokens stay valid across restarts/instances.
CSRF_KEY=

# ---- Optional overrides (defaults shown) ----
# APP_ENV=development     # "production" enables JSON logs, HSTS, secure cookies
# HTTP_ADDR=:8080         # listen address
# DB_PATH=vacation.db     # SQLite database file path
